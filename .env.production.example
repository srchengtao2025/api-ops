# =====================================================================
# api-ops 生产环境 .env 模板
# 复制为 .env，按说明填入真实值
# 注意: .env 已被 .gitignore 排除，不会被 commit
# =====================================================================

# ===== 服务自身 =====
PORT=8088
GIN_MODE=release
LOG_LEVEL=info

# ===== OPS 自有 DB =====
# ⚠️ 如果用本仓库的 docker-compose.prod.yml（自带 PG 容器），下面这行可以注释掉
#    容器内会通过 environment 块自动注入 OPS_DB_DSN
#    如果你用外部 PG 实例，把下面的 host/port/user/password/dbname 改成你的
OPS_DB_DSN=host=127.0.0.1 port=5432 user=api_ops password=change_me dbname=api_ops sslmode=disable TimeZone=Asia/Shanghai

# ===== Redis =====
# 同上：prod compose 自带 Redis，REDIS_ADDR=redis:6379 会被容器环境自动注入
# 如果用外部 Redis，改 REDIS_ADDR
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# =====================================================================
# ⭐ 必填: new-api 只读 DB 连接信息（用户在另一台服务器）
# 格式: host=端口  port=端口  user=用户  password=密码  dbname=数据库
# 用户建议: 在 new-api PG 上单独建一个只读账号，GRANT SELECT ON ALL TABLES
# =====================================================================
API_OPS_RO_DSN=host=PLEASE_FILL_HOST port=5432 user=upstream_ro password=PLEASE_FILL_PASSWORD dbname=newapi sslmode=disable TimeZone=Asia/Shanghai

# =====================================================================
# ⭐ 必填: new-api Admin API 配置
# 用户的 admin 长期 token（登录 new-api 后台 → 系统设置 → 访问令牌 → 长期令牌）
# =====================================================================
upstream_ADMIN_BASE_URL=https://www.upstream.com
API_OPS_ADMIN_TOKEN=PLEASE_FILL_ADMIN_TOKEN

# ===== 对账业务参数 =====
QUOTA_PER_UNIT=500000
USD_CNY_RATE=7.20
DISPLAY_CURRENCY=CNY
UPSTREAM_IMPORT_MAX_ROWS=50000
DAILY_STMT_CRON=0 2 * * *

# ===== AI 分析 (P3 启用) =====
# 可选，留空则 AI 模块降级为 LLM-only
upstream_LLM_BASE_URL=
API_OPS_LLM_API_KEY=
upstream_LLM_MODEL=claude-sonnet-4-5

# ===== 通知出口 (P1 告警) =====
# 可选，至少配一个 webhook 才会发告警
DINGTALK_WEBHOOK=
FEISHU_WEBHOOK=
WECOM_WEBHOOK=

# ===== 容器编排专用 =====
# docker-compose.prod.yml 会读取这个作为 PG root 密码
OPS_PG_PASSWORD=api_change_me_change_me
