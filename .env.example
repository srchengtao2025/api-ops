# api-ops 配置文件示例
# 复制为 .env 并填入实际值

# ===== 服务自身 =====
PORT=8088
GIN_MODE=release          # debug | release | test
LOG_LEVEL=info            # debug | info | warn | error

# ===== api-ops 自有 DB (读写) =====
# 独立 database，名字建议 api_ops
OPS_DB_DSN=host=127.0.0.1 port=5432 user=api_ops password=change_me dbname=api_ops sslmode=disable TimeZone=Asia/Shanghai

# ===== Redis (独立实例) =====
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== upstream / newapi 数据库 (只读) =====
# 用一个只读账号，参考 GRANT SELECT ON ALL TABLES ...
API_OPS_RO_DSN=host=127.0.0.1 port=5432 user=upstream_ro password=ro_pwd dbname=newapi sslmode=disable TimeZone=Asia/Shanghai

# ===== upstream Admin API =====
# 用于调用 newapi 后台接口；强烈建议用环境变量长期 token，启动时验证后存自有 DB 加密
upstream_ADMIN_BASE_URL=https://www.upstream.com
API_OPS_ADMIN_TOKEN=sk-admin-xxxxx

# ===== 对账业务参数 =====
# 内部 quota 单位换算：1 USD = 500000 quota (与 newapi 默认 QuotaPerUnit 一致)
QUOTA_PER_UNIT=500000
# 美元对人民币汇率（用于报表展示）
USD_CNY_RATE=7.20
# 默认币种展示
DISPLAY_CURRENCY=CNY     # USD | CNY

# ===== 上游价目表导入 =====
# 单文件最大行数
UPSTREAM_IMPORT_MAX_ROWS=50000

# ===== 调度 =====
# 每日对账生成时间（cron 表达式，5 字段）
DAILY_STMT_CRON=0 2 * * *      # 每天凌晨 2:00 生成昨日对账

# ===== AI 分析 (P3 启用) =====
# 复用 upstream 网关自身的模型
upstream_LLM_BASE_URL=https://www.upstream.com/v1
API_OPS_LLM_API_KEY=sk-xxx
upstream_LLM_MODEL=claude-sonnet-4-5

# ===== 通知出口 (P1 启用) =====
# 钉钉 / 飞书 / 企微 webhook
DINGTALK_WEBHOOK=
FEISHU_WEBHOOK=
WECOM_WEBHOOK=
ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=